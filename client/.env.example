# ── React App Environment Variables ──────────────────
# NOTE: All variables MUST start with REACT_APP_ to be picked up by CRA

# API base URL — only needed if NOT using the "proxy" field in package.json
# For local dev with proxy set to http://localhost:5000, leave this blank.
# REACT_APP_API_URL=http://localhost:5000/api

# For production, set this to your deployed backend URL:
# REACT_APP_API_URL=https://your-api.onrender.com/api
